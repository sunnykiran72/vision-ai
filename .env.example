APP_ENV=local

# Resident GPU runtimes. For wardrobe-only testing use RESIDENT_RUNTIMES=wardrobe.
RESIDENT_RUNTIMES=wardrobe,tryon,upscale

# Single process-wide GPU execution queue shared by all GPU-backed features.
SYSTEM_QUEUE_MAX_SIZE=8
SYSTEM_QUEUE_WAIT_TIMEOUT_SECONDS=30

JWT_ACCESS_SECRET=

AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=
# Private wardrobe containers (input/output images are kept separate).
AZURE_WARDROBE_INPUT_CONTAINER=wardrobe-inputs
AZURE_WARDROBE_OUTPUT_CONTAINER=wardrobe-outputs

# Wardrobe extraction runs on the diffusers QwenImageEditPlus backend (see
# docs/diffusers-inference-parity.md). On the pod the model and LoRAs live under /mnt:
#   QWEN_IMAGE_EDIT_MODEL_PATH=/mnt/models/qwen-image-edit-2511
QWEN_IMAGE_EDIT_MODEL_PATH=/workspace/models/qwen-image-edit-2511
# AI_TOOLKIT_ROOT is only required when the tryon runtime is resident.
AI_TOOLKIT_ROOT=/workspace/ai-toolkit
# Extraction LoRAs: top 23k / bottom 30k / dress 27k.
WARDROBE_LORA_TOP_PATH=
WARDROBE_LORA_BOTTOM_PATH=
WARDROBE_LORA_DRESS_PATH=
# MiniCPM-V garment captioner, loaded in-process via vLLM (model id or local path).
MINICPM_MODEL_PATH=openbmb/MiniCPM-V-4_5
GLAMIFY_API_BASE_URL=
TRYON_LORA_PATH=
TRYON_LORA_WEIGHT_NAME=
TRYON_LORA_RANK=64
TRYON_LORA_ALPHA=64
TRYON_LORA_SCALE=1.0
TRYON_ENABLED_SPECIALISTS=top,bottom,dress,multi
TRYON_DEFAULT_SEED=43
TRYON_DEFAULT_STEPS=25
TRYON_DEFAULT_GUIDANCE_SCALE=1.0
TRYON_GUIDANCE_RESCALE=0.0
TRYON_DO_CFG_NORM=false
TRYON_SAMPLER=flowmatch
TRYON_OUTPUT_WIDTH=1024
TRYON_OUTPUT_HEIGHT=1536
TRYON_PREVIEW_WIDTH=896
TRYON_PREVIEW_HEIGHT=1344
TRYON_PREVIEW_STEPS=20
TRYON_QUEUE_MAX_SIZE=8
TRYON_QUEUE_WAIT_TIMEOUT_SECONDS=30
TRYON_WORK_ROOT=/tmp/glamify/tryon
TRYON_STORAGE_PREFIX=wardrobe_output/tryon

UPSCALE_MODEL_PATH=/workspace/models/upscale/seedvr2
UPSCALE_MODEL_VARIANT=seedvr2_ema_7b_fp8_e4m3fn_mixed_block35_fp16.safetensors
UPSCALE_CLI_PATH=/workspace/seedvr2_eval/ComfyUI-SeedVR2_VideoUpscaler/inference_cli.py
UPSCALE_QUEUE_MAX_SIZE=8
UPSCALE_QUEUE_WAIT_TIMEOUT_SECONDS=30
UPSCALE_WORK_ROOT=/tmp/glamify/upscale
UPSCALE_STORAGE_PREFIX=wardrobe_output/upscale
