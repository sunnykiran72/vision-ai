APP_ENV=runpod
# wardrobe + tryon share ONE resident Qwen pipeline. No SeedVR2/upscale runtime in this deploy
# (the inline try-on upscale was removed) -> it is intentionally omitted, which frees its VRAM and
# means /ready never gates on it. user_validation needs no resident runtime (person-detection loads
# on demand).
RESIDENT_RUNTIMES=wardrobe,tryon

SYSTEM_QUEUE_MAX_SIZE=8
SYSTEM_QUEUE_WAIT_TIMEOUT_SECONDS=30

JWT_ACCESS_SECRET=
JWT_ALGORITHM=HS256

AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=
AZURE_WARDROBE_INPUT_CONTAINER=wardrobe-inputs
AZURE_WARDROBE_OUTPUT_CONTAINER=wardrobe-outputs

QWEN_IMAGE_EDIT_MODEL_PATH=/workspace/models/qwen-image-edit-2511
QWEN_IMAGE_EDIT_DTYPE=bfloat16
# Fastest inference + lowest VRAM on the RTX 6000 Pro (Blackwell): torch.compile via
# compile_repeated_blocks (shape-agnostic, ~7.8s vs ~18-22s eager) + torchao fp8 dynamic
# (-33% VRAM). Requires CUDA 13 driver + torchao in the GPU stack (warmup runs a real generation
# at startup to compile/quantize the SHARED wardrobe+tryon pipeline, gated by /ready). Set both to
# false only for CPU/local tests or to fall back to bf16 (slower, more VRAM, marginally crisper).
QWEN_COMPILE=true
QWEN_FP8=true
WARDROBE_LORA_TOP_PATH=/workspace/loras/wardrobe/top_23000.safetensors
WARDROBE_LORA_BOTTOM_PATH=/workspace/loras/wardrobe/bottom_30000.safetensors
WARDROBE_LORA_DRESS_PATH=/workspace/loras/wardrobe/dress_27000.safetensors

MINICPM_MODEL_PATH=/workspace/models/minicpm-v-4_5-awq
MINICPM_DTYPE=auto
MINICPM_GPU_MEMORY_UTILIZATION=0.10
MINICPM_KV_CACHE_DTYPE=auto
MINICPM_CALCULATE_KV_SCALES=false
MINICPM_ATTENTION_BACKEND=
MINICPM_MAX_TOKENS=100
MINICPM_MAX_MODEL_LEN=2048
MINICPM_MAX_SLICE_NUMS=6
MINICPM_RESIZE_LONG_PX=1024
MINICPM_ENFORCE_EAGER=false

GLAMIFY_API_BASE_URL=

# Enable tryon only after diffusers try-on LoRAs are staged.
TRYON_LORA_RANK=64
TRYON_LORA_ALPHA=64
TRYON_LORA_SCALE=1.0
TRYON_ENABLED_SPECIALISTS=top,bottom,dress,multi
TRYON_LORA_TOP_PATH=/workspace/loras/tryon/top.safetensors
TRYON_LORA_BOTTOM_PATH=/workspace/loras/tryon/bottom.safetensors
TRYON_LORA_DRESS_PATH=/workspace/loras/tryon/dress.safetensors
TRYON_LORA_MULTI_PATH=/workspace/loras/tryon/multi.safetensors
TRYON_DEFAULT_SEED=43
TRYON_DEFAULT_STEPS=12
TRYON_DEFAULT_GUIDANCE_SCALE=1.0
TRYON_STORAGE_PREFIX=wardrobe_output/tryon

# --- SeedVR2 upscale: INACTIVE in this deploy (upscale not in RESIDENT_RUNTIMES) ---
# These are ignored unless you add `upscale` back to RESIDENT_RUNTIMES. Kept for reference.
# UPSCALE_MODEL_PATH=/workspace/models/seedvr2
# UPSCALE_MODEL_VARIANT=seedvr2_ema_7b_fp8_e4m3fn_mixed_block35_fp16.safetensors
# UPSCALE_CLI_PATH=/workspace/seedvr2_eval/ComfyUI-SeedVR2_VideoUpscaler/inference_cli.py
# UPSCALE_QUEUE_MAX_SIZE=8
# UPSCALE_QUEUE_WAIT_TIMEOUT_SECONDS=30
# UPSCALE_WORK_ROOT=/workspace/tmp/glamify/upscale
# UPSCALE_STORAGE_PREFIX=wardrobe_output/upscale
