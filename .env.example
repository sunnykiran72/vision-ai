APP_ENV=local
STARTUP_WARMUP_ENABLED=true

JWT_ACCESS_SECRET=

AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

TRYON_MODEL_PATH=/workspace/models/tryon/flux
TRYON_LORA_PATH=
